---
// 星等顯示元件:視覺化 1–5 顆星,支援半顆星(例如 3.5 顆 → ★★★⯨☆)
// 做法:每顆星疊兩層字元,底層灰色、上層琥珀色依該顆星該有的填滿比例裁切寬度
interface Props {
  stars: number;
}

const { stars } = Astro.props;
const MAX = 5;
---

<span
  class="inline-flex items-center gap-0.5"
  role="img"
  aria-label={`${stars} 顆星（滿分 ${MAX} 顆）`}
>
  {
    Array.from({ length: MAX }, (_, i) => {
      const fraction = Math.min(1, Math.max(0, stars - i));
      return (
        <span class="relative inline-block" aria-hidden="true">
          <span class="text-stone-300">★</span>
          {fraction > 0 && (
            <span
              class="absolute inset-0 overflow-hidden text-amber-500"
              style={`width: ${fraction * 100}%`}
            >
              ★
            </span>
          )}
        </span>
      );
    })
  }
</span>

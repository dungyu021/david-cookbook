---
// 料理詳細頁(繁體中文版)
// 結構:照片 gallery → 菜名/星等/標籤 → 烹調時間 → 食材清單 → 完整食譜
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StarRating from '../../components/StarRating.astro';

export async function getStaticPaths() {
  const dishes = await getCollection(
    'dishes',
    (d) => d.id.endsWith('/zh') && !d.data.draft,
  );
  return dishes.map((dish) => ({
    params: { slug: dish.id.split('/')[0] },
    props: { dish },
  }));
}

const { dish } = Astro.props;
// gallery = 封面照 + 其餘照片
const photos = [dish.data.cover, ...dish.data.images];
// 食譜本文(Markdown → HTML)
const { Content } = await render(dish);
---

<BaseLayout title={`${dish.data.title}｜伏魔諭廚子`}>
  <main class="mx-auto max-w-2xl pb-16">
    {/* 照片 gallery:手機上左右滑動(CSS scroll-snap),另有半透明箭頭按鈕提示可以翻頁 */}
    <div class="relative">
      <div
        id="gallery"
        class="flex snap-x snap-mandatory gap-2 overflow-x-auto"
        aria-label="料理照片"
      >
        {
          photos.map((photo, i) => (
            <Image
              src={photo}
              alt={`${dish.data.title} 照片 ${i + 1}`}
              widths={[640, 1280]}
              sizes="(min-width: 672px) 672px, 100vw"
              class="aspect-[4/3] w-full flex-shrink-0 snap-center object-cover"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          ))
        }
      </div>

      {
        /* 只有一張照片時不顯示箭頭 */
        photos.length > 1 && (
          <>
            <button
              type="button"
              id="gallery-prev"
              aria-label="上一張照片"
              class="absolute left-3 top-1/2 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-black/35 text-white backdrop-blur-sm transition hover:bg-black/55"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M15 18l-6-6 6-6" />
              </svg>
            </button>
            <button
              type="button"
              id="gallery-next"
              aria-label="下一張照片"
              class="absolute right-3 top-1/2 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-black/35 text-white backdrop-blur-sm transition hover:bg-black/55"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 6l6 6-6 6" />
              </svg>
            </button>
          </>
        )
      }
    </div>

    <div class="px-4 sm:px-6">
      {/* 菜名、星等、標籤 */}
      <header class="mt-6">
        <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">
          {dish.data.title}
        </h1>
        <div class="mt-2">
          <StarRating stars={dish.data.stars} />
        </div>
        <ul class="mt-3 flex flex-wrap gap-1.5">
          {
            dish.data.tags.map((tag) => (
              <li class="rounded-full bg-stone-100 px-2.5 py-0.5 text-xs text-stone-600">
                #{tag}
              </li>
            ))
          }
        </ul>
      </header>

      {/* 烹調時間 */}
      <p class="mt-5 text-sm text-stone-500">
        🕐 預估烹調時間：約 {dish.data.cookingTimeMinutes} 分鐘
      </p>

      {/* 食材清單 */}
      <section class="mt-8">
        <h2 class="text-lg font-semibold">食材</h2>
        <ul class="mt-3 divide-y divide-stone-100 rounded-xl bg-white ring-1 ring-stone-200/60">
          {
            dish.data.ingredients.map((item) => (
              <li class="flex items-center justify-between px-4 py-2.5 text-sm">
                <span>{item.name}</span>
                <span class="text-stone-500">{item.amount}</span>
              </li>
            ))
          }
        </ul>
      </section>

      {/* 完整食譜本文(公開顯示) */}
      <section class="mt-8">
        <div class="prose prose-stone mt-3 max-w-none prose-headings:text-lg">
          <Content />
        </div>
      </section>

      <p class="mt-8">
        <a href="/" class="text-sm text-stone-500 underline underline-offset-4">
          ← 回料理清單
        </a>
      </p>
    </div>
  </main>
</BaseLayout>

<script>
  // 照片 gallery 的箭頭按鈕:點擊捲動一張照片的寬度,
  // 滑到最前/最後時自動隱藏對應方向的箭頭。
  // 按下按鈕的瞬間就以「目的地位置」判斷箭頭顯示,
  // 所以滑向最後一張/滑回第一張時,箭頭會立刻消失,不用等動畫結束。
  const gallery = document.getElementById('gallery');
  const prev = document.getElementById('gallery-prev');
  const next = document.getElementById('gallery-next');

  if (gallery && prev && next) {
    // 按鈕觸發的滑動目的地;null 代表沒有進行中的按鈕滑動
    let target: number | null = null;

    const updateArrows = () => {
      // 有目的地時用目的地判斷,否則用目前實際位置
      const pos = target ?? gallery.scrollLeft;
      const atStart = pos <= 4;
      const atEnd = pos + gallery.clientWidth >= gallery.scrollWidth - 4;
      prev.classList.toggle('opacity-0', atStart);
      prev.classList.toggle('pointer-events-none', atStart);
      next.classList.toggle('opacity-0', atEnd);
      next.classList.toggle('pointer-events-none', atEnd);
    };

    const slide = (direction: number) => {
      const maxScroll = gallery.scrollWidth - gallery.clientWidth;
      target = Math.max(
        0,
        Math.min(maxScroll, gallery.scrollLeft + direction * gallery.clientWidth),
      );
      updateArrows(); // 立刻依目的地更新箭頭
      gallery.scrollTo({ left: target, behavior: 'smooth' });
    };

    prev.addEventListener('click', () => slide(-1));
    next.addEventListener('click', () => slide(1));

    gallery.addEventListener(
      'scroll',
      () => {
        // 抵達目的地後解除鎖定,恢復用實際位置判斷(手指滑動也走這裡)
        if (target !== null && Math.abs(gallery.scrollLeft - target) < 4) {
          target = null;
        }
        updateArrows();
      },
      { passive: true },
    );
    // 部分瀏覽器支援 scrollend:滑動結束時保險再解除一次鎖定
    gallery.addEventListener('scrollend', () => {
      target = null;
      updateArrows();
    });
    window.addEventListener('resize', updateArrows);
    updateArrows();
  }
</script>

---
// 首頁:料理清單(繁體中文版)
// Phase 2 會在這裡加上篩選與排序面板(React island)
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import DishCard from '../components/DishCard.astro';

// 只取繁中版(zh.md)且非草稿的料理,預設最新在前
const dishes = (
  await getCollection('dishes', (d) => d.id.endsWith('/zh') && !d.data.draft)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="David 的料理菜單">
  <main class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
    <header class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight">David 的料理菜單</h1>
      <p class="mt-2 text-stone-500">做過的每一道菜,都在這裡。</p>
    </header>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {dishes.map((dish) => <DishCard dish={dish} />)}
    </div>
  </main>
</BaseLayout>
